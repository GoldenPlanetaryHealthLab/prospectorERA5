# .envrc
# Project-local environment for prospectorERA5Land.

source /n/home03/ttapera/software/spack/share/spack/setup-env.sh

export PROJECT_DIR="$PWD"
export PROJECT_ROOT="$PWD"

# Activate this directory as a Spack environment.
spack env activate --create -p -d .

# Avoid leaking host/system R and compiler settings.
unset R_HOME
unset CPATH
unset C_INCLUDE_PATH
unset CPLUS_INCLUDE_PATH
unset LIBRARY_PATH
unset PKG_CONFIG_PATH

# Stable Spack view paths.
SPACK_VIEW="$PROJECT_DIR/.spack-env/view"
export SPACK_VIEW

# Prefer the Spack environment view.
PATH_add="$SPACK_VIEW/bin"
if [ -d "$PATH_add" ]; then
  export PATH="$PATH_add:$PATH"
fi

# Project-local R package library.
export R_LIBS_USER="$PROJECT_DIR/rv/library/4.5/x86_64/redhat8"

# Runtime library paths.
if [ -d "$SPACK_VIEW/lib" ]; then
  export LD_LIBRARY_PATH="$SPACK_VIEW/lib:${LD_LIBRARY_PATH:-}"
fi

if [ -d "$SPACK_VIEW/lib64" ]; then
  export LD_LIBRARY_PATH="$SPACK_VIEW/lib64:${LD_LIBRARY_PATH:-}"
fi

if [ -d "$SPACK_VIEW/rlib/R/lib" ]; then
  export LD_LIBRARY_PATH="$SPACK_VIEW/rlib/R/lib:${LD_LIBRARY_PATH:-}"
fi

# Temporary explicit libxml2 fallback.
LIBXML2_LIB="/n/home03/ttapera/software/spack/opt/spack/linux-icelake/libxml2-2.15.1-3notlytf5el3yo4wbdmu5qrpingms7ch/lib"

if [ -d "$LIBXML2_LIB" ]; then
  export LD_LIBRARY_PATH="$LIBXML2_LIB:${LD_LIBRARY_PATH:-}"
fi